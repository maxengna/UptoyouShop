# Server
PORT=3001
NODE_ENV=development

# Database
# DATABASE_URL=DATABASE_URL="postgresql://postgres:1234@172.26.243.70:5432/uptoyoushop"
# DATABASE_URL=DATABASE_URL="postgresql://postgres:1234@172.26.243.70:5432/uptoyoushop"
DATABASE_URL=DATABASE_URL="postgresql://admin:1234@localhost:5432/uptoyoushop"

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRATION=7d

# AWS S3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_PRODUCTS_BUCKET=bucket-for-products
AWS_S3_CATEGORIES_BUCKET=bucket-for-categories

# CORS
CORS_ORIGIN=http://localhost:3000

# Cookie
COOKIE_SECRET=your-cookie-secret
