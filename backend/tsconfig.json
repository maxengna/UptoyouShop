{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "paths": {
      "@/*": ["src/*"],
      "@config/*": ["src/config/*"],
      "@common/*": ["src/common/*"],
      "@prisma/*": ["src/prisma/*"],
      "@auth/*": ["src/auth/*"],
      "@users/*": ["src/users/*"],
      "@products/*": ["src/products/*"],
      "@cart/*": ["src/cart/*"],
      "@orders/*": ["src/orders/*"],
      "@admin/*": ["src/admin/*"],
      "@reviews/*": ["src/reviews/*"]
    }
  }
}
