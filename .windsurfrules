    product/[slug]/page.tsx
    category/[slug]/page.tsx
    cart/page.tsx
    checkout/page.tsx
  /(auth)           # Authentication routes
    login/page.tsx
    register/page.tsx
  /(admin)          # Admin routes group
    dashboard/page.tsx
    products/page.tsx
    orders/page.tsx
  api/              # API routes
    products/
