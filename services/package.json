{
  "name": "uptoyoushop",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "../database/schema.prisma",
    "seed": "../database/seed.ts"
  },
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push --schema ../database/schema.prisma",
    "db:seed": "tsx ../database/seed.ts",
    "db:studio": "prisma studio --schema ../database/schema.prisma",
    "db:generate": "prisma generate --schema ../database/schema.prisma",
    "postinstall": "prisma generate --schema ../database/schema.prisma && if exist ..\\backend\\node_modules\\.prisma\\client (xcopy /E /Y /I ..\\backend\\node_modules\\.prisma\\client node_modules\\.prisma\\client >nul 2>&1 && xcopy /E /Y /I ..\\backend\\node_modules\\.prisma\\client ..\\node_modules\\.prisma\\client >nul 2>&1)"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1075.0",
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "next": "14.0.0",
    "next-auth": "^4.24.0",
    "prisma": "^5.0.0",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5"
  }
}
